{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "V3.5 agent ask: planner executor",
			"type": "debugpy",
			"request": "launch",
			"module": "obsidian_rag.cli",
			"console": "integratedTerminal",
			"cwd": "${workspaceFolder}",
			"python": "${workspaceFolder}/.venv/bin/python",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"RAG_DEBUG_BREAKPOINTS": "search.after_query_embedding,qdrant.after_search,search.after_retrieval,prompting.messages_built"
			},
			"args": [
				"agent-v3-5",
				"ask",
				"帮我总结生鸡肉处理、厨房清洁、剩菜保存三类食品安全建议",
				"--top-k",
				"5",
				"--mode",
				"hybrid",
				"--max-steps",
				"4"
			],
			"justMyCode": true
		},
		{
			"name": "V3.4 planner: structured plan",
