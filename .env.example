OPENAI_API_KEY=your-local-cliproxy-key
OPENAI_BASE_URL=http://127.0.0.1:8317/v1

RAG_CHAT_MODEL=gpt-5.4-mini
RAG_EMBED_MODEL=qwen3-embedding:0.6b
RAG_EMBED_DIMENSIONS=1024
RAG_EMBED_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

RAG_VAULT_PATH=/path/to/your/ObsidianVault
QDRANT_URL=http://127.0.0.1:6333
RAG_DB_PATH=.rag/qdrant
RAG_COLLECTION=obsidian_notes
RAG_DOCUMENT_PARSER=docling
RAG_DOCLING_TOKENIZER_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_CHUNK_TOKENS=512
RAG_MIN_SCORE=0.35

# Conversation Memory uses MySQL; the SQLite path is only used by the migration script.
RAG_MYSQL_HOST=127.0.0.1
RAG_MYSQL_PORT=3306
RAG_MYSQL_USER=root
RAG_MYSQL_PASSWORD=
RAG_MYSQL_DATABASE=obsidian_rag
# RAG_MYSQL_SOCKET=/opt/homebrew/var/mysql/mysql.sock
RAG_SKILL_ROOT=skills
