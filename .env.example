OPENAI_API_KEY=your-local-cliproxy-key
OPENAI_BASE_URL=http://127.0.0.1:8317/v1

RAG_CHAT_MODEL=gpt-5.4-mini
# CPA 学习调试扩展：开启后请求 reasoning_content 并发布独立 reasoning_delta。
RAG_REASONING_STREAM_ENABLED=true
RAG_REASONING_EFFORT=medium
RAG_EMBED_MODEL=qwen3-embedding:0.6b
RAG_EMBED_DIMENSIONS=1024
RAG_EMBED_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

RAG_VAULT_PATH=/path/to/your/ObsidianVault
QDRANT_URL=http://127.0.0.1:6333
RAG_DB_PATH=.rag/qdrant
# 默认知识库 Collection；API JSON 与 CLI --collection 可在单次请求中覆盖它。
RAG_COLLECTION=obsidian_notes
RAG_DOCLING_TOKENIZER_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_TOKENS=512
RAG_CHUNK_STRATEGY=adaptive_parent_child
RAG_PARENT_CHUNK_TOKENS=1000
RAG_CHILD_CHUNK_TOKENS=400
RAG_CHILD_CHUNK_OVERLAP=40
RAG_RERANK_ENABLED=false
RAG_RERANK_PROVIDER=sentence_transformers
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_CANDIDATES=20
RAG_RERANK_TOP_K=5
RAG_RERANK_TIMEOUT_SECONDS=10
RAG_RERANK_DEVICE=auto
RAG_RERANK_BATCH_SIZE=8
RAG_MIN_SCORE=0.35

# Conversation Memory uses MySQL; the SQLite path is only used by the migration script.
RAG_MYSQL_HOST=127.0.0.1
RAG_MYSQL_PORT=3306
RAG_MYSQL_USER=root
RAG_MYSQL_PASSWORD=
RAG_MYSQL_DATABASE=obsidian_rag
# RAG_MYSQL_SOCKET=/opt/homebrew/var/mysql/mysql.sock
RAG_SKILL_ROOT=skills
# V3.12 每次 stdio MCP initialize/list/call 的最长等待时间。
RAG_MCP_TIMEOUT_SECONDS=15
# MCP Tool Result 进入 API/未来 Agent Context 前允许的最大 UTF-8 JSON 字节数。
RAG_MCP_MAX_RESULT_BYTES=262144
# V3.12.3 配置驱动的持久 MCP Server Registry。
RAG_MCP_SERVER_REGISTRY=mcp_servers.yaml
# V3.12.4 自动知识库范围路由使用的 Registry。
RAG_KNOWLEDGE_BASE_REGISTRY=knowledge_bases.yaml
# Streamable HTTP 示例 Server 的 Authorization 完整值，例如 Bearer xxx；默认 Server 关闭。
# REMOTE_MCP_AUTHORIZATION=
